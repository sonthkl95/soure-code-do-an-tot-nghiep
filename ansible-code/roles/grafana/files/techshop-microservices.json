{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "techshop-overview",
  "title": "TechShop Application Metrics (Spring Boot)",
  "description": "Application-tier metrics cho TechShop microservices: Golden Signals (RED) + JVM + HikariCP. Logs xem ở Grafana Explore (Loki datasource).",
  "tags": ["techshop", "app", "spring-boot"],
  "timezone": "Asia/Ho_Chi_Minh",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus DS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" },
        "hide": 0
      },
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(up{namespace=\"techshop\"}, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "app",
        "label": "App",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(up{namespace=\"techshop\", cluster=~\"$cluster\"}, app)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "🟢 Service Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "id": 100,
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Per-Service UP Status",
      "gridPos": { "x": 0, "y": 1, "w": 24, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max by (app, cluster) (up{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"})",
          "legendFormat": "{{cluster}} / {{app}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "name",
        "orientation": "auto",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },

    {
      "type": "row",
      "title": "🌐 HTTP — Golden Signals (RED)",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 },
      "id": 101,
      "collapsed": false
    },
    {
      "id": 9,
      "type": "stat",
      "title": "HTTP Success Rate % (5m window)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * (1 - (sum by (app) (rate(http_server_requests_seconds_count{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\", status=~\"5..\"}[5m])) / clamp_min(sum by (app) (rate(http_server_requests_seconds_count{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m])), 0.0001)))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "orientation": "auto",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 99 }, { "color": "green", "value": 99.9 }] }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (rate(http_server_requests_seconds_count{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "showPoints": "never", "spanNulls": true }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "HTTP Error Rate by Status Class (req/s)",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (rate(http_server_requests_seconds_count{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\", status=~\"4..\"}[5m]))",
          "legendFormat": "{{app}} 4xx",
          "refId": "A"
        },
        {
          "expr": "sum by (app) (rate(http_server_requests_seconds_count{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\", status=~\"5..\"}[5m]))",
          "legendFormat": "{{app}} 5xx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "auto", "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*5xx" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*4xx" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "HTTP Latency Percentiles (p50 / p95 / p99)",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (app, le) (rate(http_server_requests_seconds_bucket{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m])))",
          "legendFormat": "{{app}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (app, le) (rate(http_server_requests_seconds_bucket{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m])))",
          "legendFormat": "{{app}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (app, le) (rate(http_server_requests_seconds_bucket{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m])))",
          "legendFormat": "{{app}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity", "showPoints": "never", "spanNulls": true }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 16,
      "type": "table",
      "title": "Top 10 Slowest Endpoints (p95, last 5m)",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (app, uri, method, le) (rate(http_server_requests_seconds_bucket{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m]))))",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "namespace": true, "cluster": true, "pod": true, "container": true, "service_name": true }, "renameByName": { "Value": "p95 (s)" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "p95 (s)", "desc": true }] } }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p95 (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 },
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } },
              { "id": "max", "value": 2 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      }
    },
    {
      "id": 17,
      "type": "table",
      "title": "Top 10 Error Endpoints (5xx rate, last 5m)",
      "gridPos": { "x": 0, "y": 46, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, sum by (app, uri, method, status) (rate(http_server_requests_seconds_count{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\", status=~\"5..\"}[5m])))",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "namespace": true, "cluster": true, "pod": true, "container": true, "service_name": true }, "renameByName": { "Value": "errors/s" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "errors/s", "desc": true }] } }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "errors/s" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "decimals", "value": 3 },
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": false } }
    },

    {
      "type": "row",
      "title": "☕ JVM",
      "gridPos": { "x": 0, "y": 54, "w": 24, "h": 1 },
      "id": 102,
      "collapsed": false
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "JVM Heap Utilization % (used / max)",
      "gridPos": { "x": 0, "y": 55, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * sum by (app) (jvm_memory_used_bytes{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\", area=\"heap\"}) / clamp_min(sum by (app) (jvm_memory_max_bytes{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\", area=\"heap\"}), 1)",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 }] },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "never", "spanNulls": true, "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Process CPU Usage",
      "gridPos": { "x": 0, "y": 63, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (process_cpu_usage{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"})",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.7 }, { "color": "red", "value": 0.9 }] }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "JVM GC Pause Rate (s/s)",
      "gridPos": { "x": 0, "y": 71, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (rate(jvm_gc_pause_seconds_sum{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "auto", "spanNulls": true }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "type": "row",
      "title": "🗄️ Database Connection Pool (HikariCP)",
      "gridPos": { "x": 0, "y": 78, "w": 24, "h": 1 },
      "id": 103,
      "collapsed": false
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "HikariCP Pool Utilization % (active / max)",
      "gridPos": { "x": 0, "y": 79, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * sum by (app, pool) (hikaricp_connections_active{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}) / clamp_min(sum by (app, pool) (hikaricp_connections_max{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}), 1)",
          "legendFormat": "{{app}} / {{pool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "never", "spanNulls": true, "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "HikariCP Pending (waiting for connection)",
      "gridPos": { "x": 0, "y": 87, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app, pool) (hikaricp_connections_pending{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"})",
          "legendFormat": "{{app}} / {{pool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "auto", "spanNulls": true, "thresholdsStyle": { "mode": "line" } }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "HikariCP Connection Timeouts (rate)",
      "gridPos": { "x": 0, "y": 94, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (rate(hikaricp_connections_timeout_total{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "continuous-RdYlGr", "fixedColor": "red" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 25, "gradientMode": "opacity", "showPoints": "auto", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
