# =============================================================
# app-secrets — Secret nhạy cảm (non-DB).
# Auto-render từ Ansible Vault (group_vars/all/vault.yml).
# KHÔNG commit file đã render — chỉ sống tạm trên master.
# =============================================================
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: {{ app_namespace }}
  labels:
    env: {{ app_env }}
type: Opaque
stringData:
  # ── Cloudinary (catalog-service) ─────────────────────────────
  CLOUDINARY_CLOUD_NAME: {{ vault_cloudinary_cloud_name | to_json }}
  CLOUDINARY_API_KEY:    {{ vault_cloudinary_api_key | to_json }}
  CLOUDINARY_API_SECRET: {{ vault_cloudinary_api_secret | to_json }}

  # ── Gmail SMTP (identity-service) ────────────────────────────
  GOOGLE_MAIL_USERNAME: {{ vault_google_mail_username | to_json }}
  GOOGLE_APP_PASSWORD: {{ vault_google_app_password | to_json }}

  # ── SePay (payment-service) ──────────────────────────────────
  SEPAY_APIKEY:  {{ vault_sepay_apikey | to_json }}
  BANK_NAME:     {{ vault_sepay_bank_name | to_json }}
  BANK_NUMBER:   {{ vault_sepay_bank_number | to_json }}
  SEPAY_CONTENT: {{ vault_sepay_content | to_json }}

  # ── VNPay (payment-service) ──────────────────────────────────
  VNPAY_URL:      {{ vault_vnpay_url | to_json }}
  VNPAY_RETURN:   {{ vault_vnpay_return | to_json }}
  VNPAY_TMNCODE:  {{ vault_vnpay_tmncode | to_json }}
  VNPAY_SECRET:   {{ vault_vnpay_secret | to_json }}
  VNPAY_APIURL:   {{ vault_vnpay_apiurl | to_json }}

  # ── OAuth2 client secrets (BFF) ──────────────────────────────
  BFF_USER_CLIENT_ID:      {{ vault_bff_user_client_id | to_json }}
  BFF_USER_CLIENT_SECRET:  {{ vault_bff_user_client_secret | to_json }}
  BFF_ADMIN_CLIENT_ID:     {{ vault_bff_admin_client_id | to_json }}
  BFF_ADMIN_CLIENT_SECRET: {{ vault_bff_admin_client_secret | to_json }}
