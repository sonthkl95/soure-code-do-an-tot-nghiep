apiVersion: v1
kind: Secret
metadata:
  name: gar-pull-secret
  namespace: techshop
type: kubernetes.io/dockerconfigjson
stringData:
  .dockerconfigjson: |
{# gar_key_content có thể là dict (Ansible auto-parse JSON) hoặc string.
   Chuẩn hoá về JSON string compact rồi mới to_json để escape sang JSON string literal. #}
{%- set _gar_key_str = gar_key_content if gar_key_content is string else (gar_key_content | to_json) %}
    {
      "auths": {
        "{{ gar_registry_host }}": {
          "username": "_json_key",
          "password": {{ _gar_key_str | to_json }},
          "email": "admin@techshop.local",
          "auth": "{{ ('_json_key:' ~ _gar_key_str) | b64encode }}"
        }
      }
    }
