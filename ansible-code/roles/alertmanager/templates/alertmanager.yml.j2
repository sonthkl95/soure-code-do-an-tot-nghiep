{# Lọc receiver đã có credential thực (bỏ qua placeholder REPLACE_WITH_*)
   để Alertmanager không crash với lỗi "unsupported scheme" / invalid URL. #}
{% set valid_receivers = [] %}
{% for r in alertmanager_receivers %}
{%   if r.type == 'telegram' and r.telegram_bot_token is defined
        and not (r.telegram_bot_token | string).startswith('REPLACE_WITH')
        and not (r.telegram_chat_id | string).startswith('REPLACE_WITH') %}
{%     set _ = valid_receivers.append(r) %}
{%   elif r.type == 'slack' and r.slack_webhook_url is defined
        and (r.slack_webhook_url | string).startswith('http') %}
{%     set _ = valid_receivers.append(r) %}
{%   elif r.type == 'email' and r.email_to is defined
        and not (r.email_to | string).startswith('REPLACE_WITH') %}
{%     set _ = valid_receivers.append(r) %}
{%   endif %}
{% endfor %}
{% set receiver_names = valid_receivers | map(attribute='name') | list %}
{% if 'telegram' in receiver_names %}
{%   set default_receiver = 'telegram' %}
{% elif 'slack' in receiver_names %}
{%   set default_receiver = 'slack' %}
{% elif 'email' in receiver_names %}
{%   set default_receiver = 'email' %}
{% else %}
{%   set default_receiver = 'null' %}
{% endif %}
# Alertmanager config - Grouping, Deduplication & Routing (per architecture)
global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'job']
  group_wait: {{ alertmanager_group_wait }}
  group_interval: {{ alertmanager_group_interval }}
  repeat_interval: {{ alertmanager_repeat_interval }}
  receiver: '{{ default_receiver }}'
  routes:
{% if 'telegram' in receiver_names %}
    - match:
        severity: critical
      receiver: 'telegram'
{% endif %}
{% if 'slack' in receiver_names %}
    - match:
        severity: warning
      receiver: 'slack'
{% endif %}

receivers:
  # Null receiver: fallback khi chưa có channel nào được cấu hình credential thực
  - name: 'null'
{% for receiver in valid_receivers %}
{% if receiver.type == 'telegram' %}
  - name: '{{ receiver.name }}'
    telegram_configs:
      - bot_token: '{{ receiver.telegram_bot_token }}'
        chat_id: {{ receiver.telegram_chat_id }}
        message: '{% raw %}{{ template "telegram.default.message" . }}{% endraw %}'
{% elif receiver.type == 'slack' %}
  - name: '{{ receiver.name }}'
    slack_configs:
      - api_url: '{{ receiver.slack_webhook_url }}'
        channel: '#alerts'
        text: '{% raw %}{{ range .Alerts }}{{ .Annotations.description }}{{ end }}{% endraw %}'
{% elif receiver.type == 'email' %}
  - name: '{{ receiver.name }}'
    email_configs:
      - to: '{{ receiver.email_to }}'
        smarthost: '{{ receiver.email_smarthost }}'
        require_tls: false
{% endif %}
{% endfor %}

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'cluster', 'instance']
