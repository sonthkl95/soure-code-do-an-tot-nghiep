{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "techshop-overview",
  "title": "TechShop Application Metrics (Spring Boot)",
  "description": "Application-tier dashboard cho TechShop microservices: Spring Boot Actuator, JVM, HikariCP, HTTP, Logs. Mỗi panel hiển thị full-width để tối ưu cho màn hình nhỏ.",
  "tags": ["techshop", "app", "spring-boot"],
  "timezone": "Asia/Ho_Chi_Minh",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus DS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" },
        "hide": 0
      },
      {
        "name": "loki_ds",
        "label": "Loki DS",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "loki" },
        "hide": 0
      },
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(up{namespace=\"techshop\"}, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "app",
        "label": "App",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(up{namespace=\"techshop\", cluster=~\"$cluster\"}, app)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "🟢 Service Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "id": 100,
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Services UP vs Total",
      "gridPos": { "x": 0, "y": 1, "w": 24, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(up{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"})",
          "legendFormat": "UP",
          "refId": "A"
        },
        {
          "expr": "count(up{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"})",
          "legendFormat": "Total",
          "refId": "B"
        },
        {
          "expr": "count(up{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"} == 0) OR on() vector(0)",
          "legendFormat": "DOWN",
          "refId": "C"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "orientation": "horizontal",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "DOWN" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Per-Service UP Status",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max by (app, cluster) (up{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"})",
          "legendFormat": "{{cluster}} / {{app}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "horizontal",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 5,
      "type": "text",
      "title": "",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "> ℹ️ **Note:** Infrastructure metrics (Pod restarts, container CPU/RAM/Network, node health) live in the **Kubernetes Cluster Overview** dashboard. This dashboard focuses purely on the **application tier** — Spring Boot Actuator, JVM, HikariCP, HTTP, Logs."
      }
    },

    {
      "type": "row",
      "title": "🌐 HTTP Traffic (Spring Boot Actuator)",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 1 },
      "id": 101,
      "collapsed": false
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (rate(http_server_requests_seconds_count{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP Error Rate 5xx (req/s)",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (rate(http_server_requests_seconds_count{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\", status=~\"5..\"}[5m]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "continuous-RdYlGr", "fixedColor": "red" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "showPoints": "auto",
            "spanNulls": true
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.1 }, { "color": "red", "value": 1 }] }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP Latency p95 (s)",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (app, le) (rate(http_server_requests_seconds_bucket{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m])))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "HTTP Latency p99 (s)",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (app, le) (rate(http_server_requests_seconds_bucket{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m])))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "type": "row",
      "title": "☕ JVM",
      "gridPos": { "x": 0, "y": 48, "w": 24, "h": 1 },
      "id": 102,
      "collapsed": false
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "JVM Heap Used",
      "gridPos": { "x": 0, "y": 49, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (jvm_memory_used_bytes{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\", area=\"heap\"})",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "mode": "none" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Process CPU Usage",
      "gridPos": { "x": 0, "y": 57, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (process_cpu_usage{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"})",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.7 }, { "color": "red", "value": 0.9 }] }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "JVM Threads Live",
      "gridPos": { "x": 0, "y": 65, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (jvm_threads_live_threads{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"})",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "JVM GC Pause Rate (s/s)",
      "gridPos": { "x": 0, "y": 72, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (rate(jvm_gc_pause_seconds_sum{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "auto",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "type": "row",
      "title": "🗄️ Database Connection Pool (HikariCP)",
      "gridPos": { "x": 0, "y": 79, "w": 24, "h": 1 },
      "id": 103,
      "collapsed": false
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "HikariCP Active Connections",
      "gridPos": { "x": 0, "y": 80, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app, pool) (hikaricp_connections_active{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"})",
          "legendFormat": "{{app}} / {{pool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "HikariCP Pending (waiting for connection)",
      "gridPos": { "x": 0, "y": 87, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app, pool) (hikaricp_connections_pending{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"})",
          "legendFormat": "{{app}} / {{pool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "auto",
            "spanNulls": true,
            "thresholdsStyle": { "mode": "line" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "HikariCP Connection Timeouts (rate)",
      "gridPos": { "x": 0, "y": 94, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (rate(hikaricp_connections_timeout_total{namespace=\"techshop\", cluster=~\"$cluster\", app=~\"$app\"}[5m]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "continuous-RdYlGr", "fixedColor": "red" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "showPoints": "auto",
            "spanNulls": true
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "type": "row",
      "title": "📜 Logs (Loki)",
      "gridPos": { "x": 0, "y": 101, "w": 24, "h": 1 },
      "id": 104,
      "collapsed": false
    },
    {
      "id": 40,
      "type": "logs",
      "title": "TechShop Logs (ERROR / WARN / Exception)",
      "gridPos": { "x": 0, "y": 102, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "targets": [
        {
          "expr": "{service_name=~\".*\"} |~ \"(?i)error|warn|exception\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
