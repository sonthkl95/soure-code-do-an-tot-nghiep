# ── Terraform state & secrets ──────────────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log

# ── Sensitive variable files ───────────────────────────────────────────────────
terraform.tfvars
*.auto.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Terraform plan output ──────────────────────────────────────────────────────
*.tfplan

# ── Ansible sensitive files ────────────────────────────────────────────────────
ansible-code/inventory/hosts
ansible-code/*.retry
*.vault_pass
vault_pass.txt

# ── SSH keys ───────────────────────────────────────────────────────────────────
*.pem
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# ── OS & editor artifacts ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp
*.swo

# ── Python virtualenv (if any scripts) ────────────────────────────────────────
.venv/
__pycache__/
*.pyc
