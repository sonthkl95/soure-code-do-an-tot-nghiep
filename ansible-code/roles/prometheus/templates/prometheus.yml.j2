global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    source: central
    site: observability-vm

# Alertmanager integration
alerting:
  alertmanagers:
    - static_configs:
        - targets: ["localhost:9093"]

# Alert rules (WAL config - prevent data loss)
rule_files:
  - "{{ prometheus_install_dir }}/rules/*.yml"

scrape_configs:
  # Scrape Prometheus itself
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  # Scrape Node Exporter on all VMs (Infra metrics: CPU/RAM/Disk/Net của host)
  # Gắn label `cluster` theo dải IP / inventory group để Grafana có thể filter
  #   dev   = k8s_dev   + db_dev   (10.10.x.x)
  #   prod  = k8s_prod  + db_prod  (10.20.x.x)
  #   infra = observability + data (10.60.x.x)
  - job_name: "node-exporter"
    static_configs:
{% set dev_hosts   = (groups.get('k8s_dev', [])   + groups.get('db_dev', [])) %}
{% set prod_hosts  = (groups.get('k8s_prod', [])  + groups.get('db_prod', [])) %}
{% set infra_hosts = (groups.get('observability', []) + groups.get('data', [])) %}
      - labels:
          cluster: dev
        targets:
{% for host in dev_hosts %}
{% if hostvars[host]['ansible_host'] is defined %}
          - "{{ hostvars[host]['ansible_host'] }}:9100"
{% endif %}
{% endfor %}
      - labels:
          cluster: prod
        targets:
{% for host in prod_hosts %}
{% if hostvars[host]['ansible_host'] is defined %}
          - "{{ hostvars[host]['ansible_host'] }}:9100"
{% endif %}
{% endfor %}
      - labels:
          cluster: infra
        targets:
{% for host in infra_hosts %}
{% if hostvars[host]['ansible_host'] is defined %}
          - "{{ hostvars[host]['ansible_host'] }}:9100"
{% endif %}
{% endfor %}
{% if prometheus_drop_high_cardinality %}
    metric_relabel_configs:
      # Drop một số metrics ít dùng nhưng nặng từ node_exporter
      - source_labels: [__name__]
        regex: 'node_(scrape_collector_.*|filesystem_device_error|textfile_.*)'
        action: drop
{% endif %}

  # ── mysqld-exporter: mysql_up, connections, queries ────────────────────────
  # db-dev (10.10.1.30:9104) và db-prod (10.20.1.30:9104)
  - job_name: "mysqld-exporter"
    static_configs:
      - labels:
          cluster: dev
        targets:
{% for host in groups.get('db_dev', []) %}
{% if hostvars[host]['ansible_host'] is defined %}
          - "{{ hostvars[host]['ansible_host'] }}:9104"
{% endif %}
{% endfor %}
      - labels:
          cluster: prod
        targets:
{% for host in groups.get('db_prod', []) %}
{% if hostvars[host]['ansible_host'] is defined %}
          - "{{ hostvars[host]['ansible_host'] }}:9104"
{% endif %}
{% endfor %}

  # ── redis-exporter: redis_up, redis_memory_used_bytes ──────────────────────
  # data-vm (10.60.1.20:9121)
  - job_name: "redis-exporter"
    static_configs:
      - labels:
          cluster: infra
        targets:
{% for host in groups.get('data', []) %}
{% if hostvars[host]['ansible_host'] is defined %}
          - "{{ hostvars[host]['ansible_host'] }}:9121"
{% endif %}
{% endfor %}

  # ── kafka-exporter: kafka_brokers, kafka_consumer_group_lag ────────────────
  # data-vm (10.60.1.20:9308)
  - job_name: "kafka-exporter"
    static_configs:
      - labels:
          cluster: infra
        targets:
{% for host in groups.get('data', []) %}
{% if hostvars[host]['ansible_host'] is defined %}
          - "{{ hostvars[host]['ansible_host'] }}:9308"
{% endif %}
{% endfor %}

# =============================================================
# Centralized Metrics Receiver
# Prometheus Server này chạy với --web.enable-remote-write-receiver.
# Hai K8s clusters (Dev + Prod) deploy "Prometheus Agent Mode"
# (role prometheus-agent) và remote_write metrics về đây qua port 9090.
#  - Mỗi cluster gắn external_label cluster=dev / cluster=prod
#  - Metrics K8s (apiserver, kubelet, cAdvisor, kube-state-metrics, app pods)
#    sẽ tự động xuất hiện trong Grafana, có thể filter bằng label `cluster`.
# =============================================================

# NOTE: storage.tsdb.path / retention.time / wal-compression là CLI flags,
# KHÔNG phải config file fields. Đã được pass qua systemd ExecStart
# (xem prometheus.service.j2). Không khai báo ở đây để tránh "field not found".
