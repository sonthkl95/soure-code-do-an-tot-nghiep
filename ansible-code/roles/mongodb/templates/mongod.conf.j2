# Managed by Ansible
storage:
  dbPath: {{ mongodb_data_dir }}
  wiredTiger:
    engineConfig:
      cacheSizeGB: {{ mongodb_wired_tiger_cache_gb }}

systemLog:
  destination: file
  logAppend: true
  path: {{ mongodb_log_dir }}/mongod.log

net:
  port: {{ mongodb_port }}
  bindIp: {{ mongodb_bind_ip }}

processManagement:
  timeZoneInfo: /usr/share/zoneinfo

replication:
  replSetName: {{ mongodb_replset_name }}
