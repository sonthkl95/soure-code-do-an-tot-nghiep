auth_enabled: false

server:
  http_listen_port: {{ loki_port }}
  grpc_listen_port: 9096

common:
  instance_addr: 127.0.0.1
  path_prefix: {{ loki_install_dir }}/data
  replication_factor: 1
  ring:
    kvstore:
      store: inmemory

# Ingester nhận log từ HTTP push (otel-gateway trên obs-vm đổ vào)
ingester:
  chunk_idle_period: 5m
  chunk_retain_period: 30s
  wal:
    enabled: true
    dir: {{ loki_install_dir }}/data/wal

# Schema v13 + TSDB (chuẩn cho Loki 3.x)
schema_config:
  configs:
    - from: 2024-01-01
      store: tsdb
      object_store: gcs
      schema: v13
      index:
        prefix: loki_index_
        period: 24h

# GCS Storage backend (Cloud-Native per architecture)
storage_config:
  tsdb_shipper:
    active_index_directory: {{ loki_install_dir }}/data/tsdb-index
    cache_location: {{ loki_install_dir }}/data/tsdb-cache
    cache_ttl: 24h
  gcs:
    bucket_name: {{ loki_gcs_bucket }}

# Compactor - merge data chunks (per architecture: Compactor operations)
compactor:
  working_directory: {{ loki_install_dir }}/data/compactor
  compaction_interval: 10m
  retention_enabled: true
  retention_delete_delay: 2h
  delete_request_store: gcs

limits_config:
  reject_old_samples: true
  reject_old_samples_max_age: {{ loki_retention_period }}
  retention_period: {{ loki_retention_period }}
  allow_structured_metadata: true

  # OTLP ingestion mapping: chỉ định resource attrs nào được promote thành label.
  # Mặc định Loki chỉ promote service.name, service.namespace, service.instance.id.
  # Thêm cluster / k8s.* để query Explore tiện hơn: {cluster="prod", k8s_namespace_name="techshop"}
  # CHÚ Ý: tên label trong LogQL bị normalize → dot/dash thành underscore
  #   cluster                 → cluster
  #   deployment.environment  → deployment_environment
  #   k8s.namespace.name      → k8s_namespace_name
  #   k8s.container.name      → k8s_container_name
  #   k8s.pod.name            → k8s_pod_name  (cardinality cao → để structured_metadata)
  #   host.name               → host_name
  otlp_config:
    resource_attributes:
      attributes_config:
        - action: index_label
          attributes:
            - cluster
            - deployment.environment
            - k8s.namespace.name
            - k8s.container.name
            - host.name
            - service.namespace
        # Pod name có cardinality cao (đổi mỗi lần restart) → giữ ở structured_metadata
        - action: structured_metadata
          attributes:
            - k8s.pod.name
            - k8s.node.name
            - host.id
    # Trace correlation: trace.id / span.id lưu thành structured_metadata để filter nhanh
    log_attributes:
      - action: structured_metadata
        attributes:
          - trace.id
          - span.id
