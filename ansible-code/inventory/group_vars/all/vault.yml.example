---
# =============================================================
# Centralized secrets (Ansible Vault)
# Áp dụng cho TOÀN BỘ host (group_vars/all auto-load) — vì:
#   - db_dev/db_prod: dùng để tạo MySQL user (role mysql)
#   - k8s_dev_master/prod_master: dùng để render Secret data-credentials (role app)
# =============================================================
# CÁCH SỬ DỤNG:
#   1. Copy file này thành `vault.yml` (cùng thư mục):
#         cp group_vars/all/vault.yml.example group_vars/all/vault.yml
#   2. Đổi giá trị placeholder thành password thật.
#   3. Mã hoá:
#         ansible-vault encrypt group_vars/all/vault.yml
#   4. Chạy playbook với:
#         ansible-playbook -i inventory/hosts.ini site.yml --ask-vault-pass
#      hoặc --vault-password-file <path>
# =============================================================

# MySQL application user passwords (4 microservice DB)
vault_mysql_payment_password:   "CHANGE_ME_payment_strong_password"
vault_mysql_inventory_password: "CHANGE_ME_inventory_strong_password"
vault_mysql_order_password:     "CHANGE_ME_order_strong_password"
vault_mysql_identity_password:  "CHANGE_ME_identity_strong_password"

# =============================================================
# App-level secrets — render thành K8s Secret `app-secrets`
# (roles/app/templates/app-secrets.yaml.j2)
# =============================================================

# Cloudinary (catalog-service image upload)
vault_cloudinary_cloud_name: "REPLACE_ME"
vault_cloudinary_api_key:    "REPLACE_ME"
vault_cloudinary_api_secret: "REPLACE_ME"

# Gmail SMTP (identity-service OTP/verification email)
vault_google_mail_username: "REPLACE_ME@gmail.com"
vault_google_app_password: "REPLACE_ME"

# SePay (payment-service)
vault_sepay_apikey:      "REPLACE_ME"
vault_sepay_bank_name:   "REPLACE_ME"
vault_sepay_bank_number: "REPLACE_ME"
vault_sepay_content:     "REPLACE_ME"

# VNPay (payment-service)
vault_vnpay_url:     "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
vault_vnpay_return:  "REPLACE_ME"
vault_vnpay_tmncode: "REPLACE_ME"
vault_vnpay_secret:  "REPLACE_ME"
vault_vnpay_apiurl:  "https://sandbox.vnpayment.vn/merchant_webapi/api/transaction"

# OAuth2 BFF clients (registered trong identity-service)
vault_bff_user_client_id:      "user-client"
vault_bff_user_client_secret:  "REPLACE_ME"
vault_bff_admin_client_id:     "admin-client"
vault_bff_admin_client_secret: "REPLACE_ME"

# Identity Service RSA Key pair (persistent across pod restarts).
# Generate 1 lần:
#   openssl genrsa -out /tmp/rsa.key 2048
#   openssl pkcs8 -topk8 -nocrypt -in /tmp/rsa.key -out /tmp/rsa_pkcs8.key
#   openssl rsa -in /tmp/rsa.key -pubout -out /tmp/rsa.pub
# Paste nội dung đầy đủ (bao gồm header BEGIN/END) vào đây dưới dạng YAML block:
vault_idp_rsa_private_key: |
  -----BEGIN PRIVATE KEY-----
  REPLACE_ME_PRIVATE_KEY_BASE64
  -----END PRIVATE KEY-----
vault_idp_rsa_public_key: |
  -----BEGIN PUBLIC KEY-----
  REPLACE_ME_PUBLIC_KEY_BASE64
  -----END PUBLIC KEY-----
